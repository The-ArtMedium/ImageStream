      "height": 640,
      "minWidth": 640,
      "minHeight": 480
    }]
  }
}
PATH: ImageStream/LocalBeat/src/index.html
<!DOCTYPE html>
<html lang="en" dir="ltr" data-theme="dark" data-scale="medium">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>LocalBeat</title>
  <link rel="stylesheet" href="css/theme.css" />
  <link rel="stylesheet" href="css/layout.css" />
  <link rel="stylesheet" href="css/accessibility.css" />
  <link rel="stylesheet" href="css/waveform.css" />
</head>
<body>

  <header class="topbar" role="banner">
    <div class="topbar__logo">
      <span aria-hidden="true">🎵</span>
      <span class="app-name">LocalBeat</span>
    </div>
    <div class="topbar__controls">
      <button id="modeToggle" class="btn btn--toggle"
        aria-label="Switch between Simple and Full mode">
        <span class="icon">⚙</span>
        <span id="modeLabel">Simple Mode</span>
      </button>
      <select id="langSelect" class="select--lang" aria-label="Select language">
        <option value="en">🌐 EN</option>
        <option value="es">🌐 ES</option>
        <option value="fr">🌐 FR</option>
        <option value="pt">🌐 PT</option>
        <option value="ar">🌐 AR</option>
        <option value="zh">🌐 ZH</option>
        <option value="hi">🌐 HI</option>
      </select>
      <button class="btn" aria-label="Open settings" onclick="openSettings()">
        <span class="icon">⚙</span>
        <span>Settings</span>
      </button>
    </div>
  </header>

  <section class="transport" role="region" aria-label="Playback controls">
    <button class="btn btn--transport" id="btnPlay" aria-label="Play">
      <span class="icon">▶</span><span>Play</span>
    </button>
    <button class="btn btn--transport" id="btnPause" aria-label="Pause">
      <span class="icon">⏸</span><span>Pause</span>
    </button>
    <button class="btn btn--transport" id="btnStop" aria-label="Stop">
      <span class="icon">⏹</span><span>Stop</span>
    </button>
    <div class="transport__time">
      <span id="currentTime">00:00</span>
      <input type="range" id="seekBar" class="seek-bar"
        min="0" max="100" value="0" aria-label="Seek position"/>
      <span id="totalTime">00:00</span>
    </div>
  </section>

  <main class="layers" id="layersContainer"
    role="main" aria-label="Audio layers">
  </main>

  <div class="add-layer">
    <button class="btn btn--add" id="btnAddLayer"
      aria-label="Add a new audio layer">
      <span class="icon">＋</span>
      <span>Add a Layer</span>
    </button>
  </div>

  <footer class="toolbar" role="toolbar" aria-label="Main tools">
    <button class="btn btn--tool" onclick="openImport()"
      aria-label="Import a sound file">
      <span class="icon">📂</span><span>Import</span>
    </button>
    <button class="btn btn--tool" onclick="openSamples()"
      aria-label="Open sample library">
      <span class="icon">🥁</span><span>Samples</span>
    </button>
    <button class="btn btn--tool" onclick="openGenerate()"
      aria-label="Generate a sound">
      <span class="icon">🎹</span><span>Generate</span>
    </button>
    <button class="btn btn--tool full-mode-only" onclick="openMix()"
      aria-label="Mix layers">
      <span class="icon">🎛</span><span>Mix</span>
    </button>
  </footer>

  <div class="actionbar">
    <button class="btn btn--save" onclick="saveProject()"
      aria-label="Save your project">
      <span class="icon">💾</span><span>Save Project</span>
    </button>
    <button class="btn btn--export" onclick="exportToLocalEdit()"
      aria-label="Send audio to LocalEdit">
      <span class="icon">📤</span><span>Send to LocalEdit</span>
    </button>
  </div>

  <div id="modalOverlay" class="modal-overlay hidden"
    role="dialog" aria-modal="true">
    <div id="modalContent" class="modal-content"></div>
  </div>

  <script src="js/i18n.js"></script>
  <script src="js/theme.js"></script>
  <script src="js/layers.js"></script>
  <script src="js/transport.js"></script>
  <script src="js/samples.js"></script>
  <script src="js/generate.js"></script>
  <script src="js/import.js"></script>
  <script src="js/export.js"></script>
  <script src="js/settings.js"></script>
  <script src="js/app.js"></script>
</body>
</html>
PATH: ImageStream/LocalBeat/src/css/theme.css
:root {
  --bg-primary:     #0e0e0e;
  --bg-secondary:   #1a1a1a;
  --bg-elevated:    #252525;
  --bg-hover:       #2e2e2e;
  --accent:         #f5a623;
  --accent-hover:   #ffb940;
  --accent-muted:   #7a5210;
  --text-primary:   #f0f0f0;
  --text-secondary: #a0a0a0;
  --text-muted:     #606060;
  --layer-1:        #1e3a5f;
  --layer-2:        #1e5f3a;
  --layer-3:        #5f3a1e;
  --layer-4:        #3a1e5f;
  --layer-5:        #5f1e3a;
  --layer-6:        #1e5f5f;
  --layer-7:        #5f5f1e;
  --layer-8:        #3a5f1e;
  --success:        #4caf50;
  --warning:        #f5a623;
  --danger:         #e53935;
  --border:         #333333;
  --font-sm:        13px;
  --font-base:      16px;
  --font-lg:        20px;
  --font-xl:        26px;
  --space-xs:       4px;
  --space-sm:       8px;
  --space-md:       16px;
  --space-lg:       24px;
  --space-xl:       32px;
  --radius:         8px;
  --radius-sm:      4px;
  --transition:     0.2s ease;
}

[data-scale="small"]  { font-size: var(--font-sm);   }
[data-scale="medium"] { font-size: var(--font-base);  }
[data-scale="large"]  { font-size: var(--font-lg);   }
[data-scale="xl"]     { font-size: var(--font-xl);   }

[data-contrast="high"] {
  --bg-primary:   #000000;
  --bg-secondary: #111111;
  --text-primary: #ffffff;
  --border:       #ffffff;
  --accent:       #ffcc00;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background-color: var(--bg-primary);
  color: var(--text-primary);
  font-family: system-ui, -apple-system, sans-serif;
  font-size: var(--font-base);
  line-height: 1.5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

*:focus-visible {
  outline: 3px solid var(--accent);
  outline-offset: 2px;
}
PATH: ImageStream/LocalBeat/src/css/layout.css
.topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-sm) var(--space-md);
  background: var(--bg-secondary);
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  z-index: 100;
}

.topbar__logo {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  font-size: 1.2em;
  font-weight: 700;
  color: var(--accent);
}

.topbar__controls {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.transport {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-sm) var(--space-md);
  background: var(--bg-secondary);
  border-bottom: 1px solid var(--border);
}

.transport__time {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  flex: 1;
  color: var(--text-secondary);
  font-variant-numeric: tabular-nums;
}

.seek-bar {
  flex: 1;
  accent-color: var(--accent);
  height: 6px;
  cursor: pointer;
}

.layers {
  flex: 1;
  padding: var(--space-md);
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  overflow-y: auto;
}

.layer {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  padding: var(--space-sm) var(--space-md);
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  min-height: 56px;
}

.layer__name {
  min-width: 80px;
  font-weight: 600;
  color: var(--text-primary);
}

.layer__waveform {
  flex: 1;
  height: 36px;
  background: var(--bg-secondary);
  border-radius: var(--radius-sm);
  border: 1px solid var(--border);
  overflow: hidden;
}

.layer__waveform canvas {
  width: 100%;
  height: 100%;
}

.layer__controls {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.add-layer {
  padding: var(--space-sm) var(--space-md);
  border-top: 1px solid var(--border);
}

.toolbar {
  display: flex;
  justify-content: space-around;
  padding: var(--space-sm) var(--space-md);
  background: var(--bg-secondary);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.actionbar {
  display: flex;
  justify-content: space-between;
  padding: var(--space-sm) var(--space-md);
  background: var(--bg-secondary);
}

.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.75);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.modal-content {
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: var(--space-lg);
  width: 90%;
  max-width: 480px;
  max-height: 80vh;
  overflow-y: auto;
}

.hidden { display: none !important; }
.full-mode-only { display: none; }
[data-mode="full"] .full-mode-only { display: flex; }
PATH: ImageStream/LocalBeat/src/css/accessibility.css
.btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-sm) var(--space-md);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  background: var(--bg-elevated);
  color: var(--text-primary);
  font-size: 1em;
  cursor: pointer;
  transition: background var(--transition), border-color var(--transition);
  min-height: 44px;
  min-width: 44px;
  white-space: nowrap;
}

.btn:hover {
  background: var(--bg-hover);
  border-color: var(--accent);
}

.btn--transport {
  background: var(--bg-secondary);
  border-color: var(--accent-muted);
  color: var(--accent);
  font-size: 1.1em;
}

.btn--tool {
  flex-direction: column;
  gap: 2px;
  font-size: 0.85em;
  padding: var(--space-xs) var(--space-sm);
}

.btn--tool .icon {
  font-size: 1.5em;
}

.btn--export {
  background: var(--accent);
  color: #000;
  border-color: var(--accent);
  font-weight: 700;
}

.btn--export:hover {
  background: var(--accent-hover);
}

.btn--add {
  width: 100%;
  justify-content: center;
  border-style: dashed;
  color: var(--text-secondary);
}

.btn--add:hover {
  color: var(--accent);
  border-color: var(--accent);
}

.volume-slider {
  width: 70px;
  accent-color: var(--accent);
  cursor: pointer;
}

.select--lang {
  background: var(--bg-elevated);
  color: var(--text-primary);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: var(--space-xs) var(--space-sm);
  font-size: 0.9em;
  cursor: pointer;
  min-height: 44px;
}

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  overflow: hidden;
  clip: rect(0,0,0,0);
  white-space: nowrap;
  border: 0;
}
PATH: ImageStream/LocalBeat/src/css/waveform.css
.waveform-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

.layer--active {
  border-color: var(--accent);
}

.layer--muted {
  opacity: 0.4;
}

.layer--muted .layer__waveform {
  filter: grayscale(1);
}

.layer-color-1 { border-left: 4px solid var(--layer-1); }
.layer-color-2 { border-left: 4px solid var(--layer-2); }
.layer-color-3 { border-left: 4px solid var(--layer-3); }
.layer-color-4 { border-left: 4px solid var(--layer-4); }
.layer-color-5 { border-left: 4px solid var(--layer-5); }
.layer-color-6 { border-left: 4px solid var(--layer-6); }
.layer-color-7 { border-left: 4px solid var(--layer-7); }
.layer-color-8 { border-left: 4px solid var(--layer-8); }

.clip-region {
  position: absolute;
  top: 0;
  height: 100%;
  background: rgba(245, 166, 35, 0.15);
  border-left: 2px solid var(--accent);
  border-right: 2px solid var(--accent);
  cursor: ew-resize;
}

.clip-handle {
  position: absolute;
  top: 0;
  width: 8px;
  height: 100%;
  background: var(--accent);
  opacity: 0.8;
  cursor: ew-resize;
}
